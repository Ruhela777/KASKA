<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#008B8B"
    android:padding="16dp">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:padding="8dp">

        <!-- Hamburger Menu Icon -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Menu" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Settings Icon -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="Settings" />

        <!-- View All Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View All"
            android:textColor="#FFFFFF"
            android:paddingStart="8dp"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Extracted Text"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_below="@id/topBar"
        android:layout_marginTop="24dp"
        android:layout_centerHorizontal="true" />

    <!-- Editable Text Area for OCR Result -->
    <EditText
        android:id="@+id/editTextExtracted"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_below="@id/titleText"
        android:layout_marginTop="16dp"
        android:background="#80CFCFCF"
        android:text="OCR Text will appear here"
        android:textSize="16sp"
        android:textColor="#000000"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:padding="16dp"
        android:elevation="4dp"
        android:hint="Extracted Text will appear here"
        android:textColorHint="#555555" />

    <!-- Buttons: Save as PDF and Print -->
    <LinearLayout
        android:id="@+id/pdfPrintButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextExtracted"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp">

        <Button
            android:id="@+id/savePdfButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save as PDF"
            android:backgroundTint="#0A9396"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/printButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Print"
            android:layout_marginStart="16dp"
            android:backgroundTint="#E9D8A6"
            android:textColor="#000000" />
    </LinearLayout>

</RelativeLayout>
