<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A9396"
    android:padding="16dp"
    tools:context=".ImageOCRActivity">

    <!-- Menu Icon -->
    <ImageView
        android:id="@+id/menuIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/menu"
        android:contentDescription="@string/desc_menu_icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Settings Icon -->
    <ImageView
        android:id="@+id/settingsIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/settings"
        android:contentDescription="@string/desc_settings_icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- View All Text -->
    <TextView
        android:id="@+id/viewAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/view_all"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:paddingTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/settingsIcon"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Document Illustration -->
    <ImageView
        android:id="@+id/documentIllustration"
        android:layout_width="131dp"
        android:layout_height="135dp"
        android:src="@drawable/kaska"
        android:contentDescription="@string/desc_document_illustration"
        app:layout_constraintTop_toBottomOf="@id/viewAll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Tagline Text -->
    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tagline_text"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/documentIllustration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Your Documents Title -->
    <TextView
        android:id="@+id/yourDocs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/your_documents"
        android:textColor="#003549"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tagline"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Upload Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/uploadCard"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/yourDocs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#94D2BD">

            <!-- Upload Image Button -->
            <Button
                android:id="@+id/selectImageButton"
                android:layout_width="200dp"
                android:layout_height="72dp"
                android:background="@drawable/upload_dotted"
                android:contentDescription="@string/desc_upload_button"
                android:text="Select Image"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                android:gravity="center"
                android:backgroundTint="@android:color/transparent"
                android:padding="8dp"
                />

            <!-- Upload Text -->
            <TextView
                android:id="@+id/uploadText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upload_image"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginTop="8dp" />

            <!-- Subtext -->
            <TextView
                android:id="@+id/subtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upload_subtext"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="@android:color/black"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Image Preview -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:background="#FFFFFF"
        android:contentDescription="@string/desc_preview_image"
        app:layout_constraintTop_toBottomOf="@id/uploadCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Upload Button -->
    <Button
        android:id="@+id/uploadButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload Get OCR"
        android:layout_marginTop="12dp"
        android:backgroundTint="#005F73"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/imageView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
